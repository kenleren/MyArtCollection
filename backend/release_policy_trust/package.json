{
  "name": "@archivale/release-policy-trust",
  "version": "0.1.0",
  "private": true,
  "description": "Provider-neutral, credential-free release policy trust core",
  "type": "module",
  "engines": {
    "node": "22.23.1"
  },
  "files": [
    "dist/src",
    "policy",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/clean.mjs && tsc -p tsconfig.json",
    "test": "npm run build --silent && node --test dist/test/*.test.js",
    "test:history": "npm run build --silent && node --test dist/test/history.test.js",
    "test:webhook": "npm run build --silent && node --test dist/test/webhook.test.js dist/test/canonical.test.js",
    "test:pagination": "npm run build --silent && node --test dist/test/pagination.test.js dist/test/paths.test.js",
    "test:receipt": "npm run build --silent && node --test dist/test/receipt.test.js",
    "test:external": "npm run build --silent && node --test dist/test/external.test.js",
    "test:conformance": "npm run build --silent && node --test dist/test/conformance.test.js",
    "test:api-boundary": "npm run build --silent && node --test dist/test/api_boundary.test.js",
    "test:ci-checkout": "npm run build --silent && node --test dist/test/ci_checkout.test.js",
    "evidence:generate": "node dist/scripts/evidence.js generate",
    "evidence:verify": "node dist/scripts/evidence.js verify",
    "policy:verify": "node dist/scripts/policy_verify.js",
    "candidate:generate": "node dist/scripts/candidate_evidence.js",
    "codeowners:verify": "node dist/scripts/codeowners_verify.js",
    "external:verify": "node dist/scripts/external_verify.js",
    "reproduce": "node dist/scripts/reproduce.js"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "typescript": "5.8.3"
  }
}
