# Local developer secrets template.
# Copy to .env.local and fill values locally. Do not commit .env.local.

# OpenAI API key for future server-side/broker experiments only.
# Do not ship this in mobile builds or expose it in Flutter/Dart code.
OPENAI_API_KEY=

# Optional local Firebase App Distribution helper value.
# This is the Firebase Android app id, not the Android package id.
FIREBASE_APP_ID=
