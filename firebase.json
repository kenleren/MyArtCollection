{
  "functions": [
    {
      "source": "backend/forms",
      "codebase": "forms",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    },
    {
      "source": "backend/broker",
      "codebase": "broker",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "hosting": {
    "public": "site",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, s-maxage=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/privacy/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, s-maxage=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/support/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, s-maxage=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/pricing/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, s-maxage=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/beta/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, s-maxage=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/blog/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, s-maxage=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/blog/collector-records-that-age-well/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, s-maxage=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/blog/how-to-organize-provenance-records-private-art-collection/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, s-maxage=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/blog/how-to-document-artwork-for-insurance-conversations/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, s-maxage=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/blog/art-inventory-template-private-collectors/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, s-maxage=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/blog/artwork-condition-report-checklist-private-collectors/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, s-maxage=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, s-maxage=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/styles.css",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600, must-revalidate"
          }
        ]
      },
      {
        "source": "/scripts/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600, must-revalidate"
          }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/site/pageview",
        "function": {
          "functionId": "sitePageview",
          "region": "us-central1"
        }
      }
    ]
  }
}
